# Required: PostgreSQL connection string
DATABASE_URL=postgresql://langfuse:CHANGE_ME@db:5432/langfuse

# Required: Secret for NextAuth.js session tokens — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME

# Required: Salt for password hashing — generate with: openssl rand -base64 32
SALT=CHANGE_ME

# Required: Public URL of the Langfuse instance
NEXTAUTH_URL=http://localhost:3000

# Optional: Encryption key for sensitive data — generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME
